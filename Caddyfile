# DAR2.cl — Caddyfile para Nixpacks (Coolify)
#
# Customiza el serving de Caddy con reglas SEO:
#   1. 410 Gone para URLs legacy de WordPress (acelera desindexacion)
#   2. Trailing slash canonico via 301 (consistente con sitemap)
#   3. Cache headers para assets versionados
#
# El redirect www -> sin-www se maneja en Coolify a nivel de dominio,
# no aqui (Traefik externo nunca pasa requests www al container).
# El HTTPS lo termina Traefik antes del container, no se configura aqui.

:{$PORT:80} {
    root * {$NIXPACKS_STATIC_ROOT:/app/dist}
    encode gzip zstd

    route {
        # ----------------------------------------
        # 1. URLs legacy de WordPress -> 410 Gone
        # ----------------------------------------
        @wpPaths path /wp-admin /wp-admin/* /wp-content /wp-content/* /wp-includes /wp-includes/* /wp-login.php /xmlrpc.php
        respond @wpPaths "Gone" 410

        @wpPhp path_regexp ^/wp-.*\.php$
        respond @wpPhp "Gone" 410

        # ----------------------------------------
        # 2. Trailing slash canonico (301)
        #    /contacto -> /contacto/
        #    No afecta la raiz, archivos con extension, ni paths con slash final.
        # ----------------------------------------
        @needsSlash {
            not path /
            not path *.*
            not path */
        }
        redir @needsSlash {path}/ 301

        # ----------------------------------------
        # 3. Cache headers
        # ----------------------------------------
        # Assets versionados por Astro: cache largo + immutable
        @astroAssets path /_astro/*
        header @astroAssets Cache-Control "public, max-age=31536000, immutable"

        # Imagenes y archivos estaticos publicos: cache de 1 semana
        @staticAssets path /favicon* /apple-touch-icon* /icon-* /og-* /robots.txt /sitemap*.xml /llms.txt /images/*
        header @staticAssets Cache-Control "public, max-age=604800"

        # ----------------------------------------
        # 4. Servir archivos estaticos
        # ----------------------------------------
        file_server {
            index index.html
        }
    }
}
