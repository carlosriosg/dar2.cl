---
import Base from '../layouts/Base.astro';

const servicioParam = Astro.url.searchParams.get('servicio') ?? '';

const breadcrumbs = [
  { name: 'Inicio', url: 'https://dar2.cl/' },
  { name: 'Contacto', url: 'https://dar2.cl/contacto/' },
];

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": "https://dar2.cl/contacto/#contactpage",
  "url": "https://dar2.cl/contacto/",
  "name": "Contacto — Cotiza tu proyecto audiovisual en 48h",
  "description": "Cotización a medida en 48 horas. Llámanos al +56 9 9843 3346 o escríbenos a dar2@dar2.cl. Av. Holanda 099, Providencia, Santiago.",
  "mainEntity": { "@id": "https://dar2.cl/#organization" }
};
---

<Base
  title="Contacto — Cotiza tu proyecto en 48h | DAR2"
  description="Cotización a medida en 48 horas. Llámanos al +56 9 9843 3346 o escríbenos a dar2@dar2.cl. Av. Holanda 099, Providencia, Santiago."
  breadcrumbs={breadcrumbs}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(contactPageSchema)} />
  </Fragment>

  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-6 pt-16 md:pt-24 pb-16">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-6">Contacto</p>
    <h1 class="text-5xl md:text-6xl font-black tracking-tight leading-[1.05] mb-6 max-w-3xl">
      Cotización en
      <em class="not-italic italic text-[#FF4500]"> 48 horas.</em>
    </h1>
    <p class="text-lg text-[#666] max-w-xl leading-relaxed">
      Cuéntanos de qué se trata tu proyecto y te armamos una propuesta detallada. Sin letra chica, sin intermediarios.
    </p>
  </section>

  <!-- Contenido -->
  <section class="max-w-7xl mx-auto px-6 pb-24 border-t border-[#e5e5e5] pt-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">

      <!-- Formulario -->
      <div>
        <h2 class="text-2xl font-black tracking-tight mb-8">Cuéntanos de tu proyecto</h2>
        <form
          id="contact-form"
          name="contacto"
          class="space-y-6"
        >
          <div>
            <label class="block text-sm font-semibold mb-2" for="nombre">Nombre</label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              required
              placeholder="Tu nombre"
              class="w-full px-4 py-3 border border-[#e5e5e5] focus:border-[#1a1a1a] outline-none text-sm transition-colors"
            />
          </div>
          <div>
            <label class="block text-sm font-semibold mb-2" for="empresa">Empresa</label>
            <input
              type="text"
              id="empresa"
              name="empresa"
              placeholder="Nombre de tu empresa"
              class="w-full px-4 py-3 border border-[#e5e5e5] focus:border-[#1a1a1a] outline-none text-sm transition-colors"
            />
          </div>
          <div>
            <label class="block text-sm font-semibold mb-2" for="email">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="tu@empresa.cl"
              class="w-full px-4 py-3 border border-[#e5e5e5] focus:border-[#1a1a1a] outline-none text-sm transition-colors"
            />
          </div>
          <div>
            <label class="block text-sm font-semibold mb-2" for="telefono">Teléfono <span class="text-[#666] font-normal">(opcional)</span></label>
            <input
              type="tel"
              id="telefono"
              name="telefono"
              placeholder="+56 9 XXXX XXXX"
              class="w-full px-4 py-3 border border-[#e5e5e5] focus:border-[#1a1a1a] outline-none text-sm transition-colors"
            />
          </div>
          <div>
            <label class="block text-sm font-semibold mb-2" for="servicio">Servicio</label>
            <select
              id="servicio"
              name="servicio"
              required
              class="w-full px-4 py-3 border border-[#e5e5e5] focus:border-[#1a1a1a] outline-none text-sm transition-colors bg-white appearance-none"
            >
              <option value="">Selecciona un servicio</option>
              <option value="streaming" selected={servicioParam === 'streaming'}>Streaming</option>
              <option value="live-shopping" selected={servicioParam === 'live-shopping'}>Live Shopping</option>
              <option value="circuito-cerrado" selected={servicioParam === 'circuito-cerrado'}>Circuito Cerrado (CCTV)</option>
              <option value="estudio-virtual" selected={servicioParam === 'estudio-virtual'}>Estudio Virtual</option>
              <option value="videos-corporativos" selected={servicioParam === 'videos-corporativos'}>Videos Corporativos</option>
              <option value="estrategias-digitales" selected={servicioParam === 'estrategias-digitales'}>Estrategias Digitales</option>
              <option value="redes-sociales" selected={servicioParam === 'redes-sociales'}>Redes Sociales</option>
              <option value="filtros-ar" selected={servicioParam === 'filtros-ar'}>Filtros AR</option>
              <option value="otro" selected={servicioParam === 'otro'}>Otro</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold mb-2" for="mensaje">Cuéntanos más</label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="5"
              required
              placeholder="Fecha estimada, tipo de proyecto, número de asistentes, plataforma objetivo..."
              class="w-full px-4 py-3 border border-[#e5e5e5] focus:border-[#1a1a1a] outline-none text-sm transition-colors resize-none"
            ></textarea>
          </div>
          <button type="submit" class="submit-btn" id="contact-submit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="22" y1="2" x2="11" y2="13"/>
              <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
            <span id="contact-submit-label">Enviar mensaje</span>
          </button>

          <!-- Mensaje de estado (oculto por default) -->
          <div id="contact-status" class="contact-status" role="status" aria-live="polite" hidden></div>
        </form>
      </div>

      <!-- Info de contacto -->
      <div class="md:pt-12">
        <div class="space-y-10">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Contacto directo</p>
            <div class="space-y-3">
              <p class="font-bold text-lg">Carlos Rios Guevara</p>
              <a
                href="https://wa.me/56998433346?text=Hola%2C%20me%20interesa%20conocer%20los%20servicios%20de%20DAR2"
                target="_blank"
                rel="noopener"
                aria-label="Escribir a DAR2 por WhatsApp"
                class="whatsapp-link"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                <span>+56 9 9843 3346</span>
              </a>
              <a href="mailto:dar2@dar2.cl" class="flex items-center gap-3 text-[#666] hover:text-[#1a1a1a] transition-colors group">
                <span class="text-sm group-hover:text-[#FF4500] transition-colors">dar2@dar2.cl</span>
              </a>
            </div>
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Ubicación</p>
            <p class="text-sm text-[#666] leading-relaxed">
              Av. Holanda 099, Oficina 603<br />
              Providencia, Santiago<br />
              Chile
            </p>
          </div>

          <div class="border border-[#e5e5e5] p-6">
            <p class="font-bold text-sm mb-2">Tiempo de respuesta</p>
            <p class="text-[#666] text-sm leading-relaxed">
              Respondemos todas las consultas en menos de <strong class="text-[#FF4500]">48 horas hábiles</strong>.
              Para urgencias, llámanos directamente.
            </p>
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Sectores</p>
            <div class="flex flex-wrap gap-2">
              {['Retail', 'Farma', 'Supermercados', 'Corporativo', 'Banca', 'Educación', 'Gremios'].map(s => (
                <span class="px-3 py-1.5 bg-[#f5f5f5] text-[#666] text-xs font-medium">{s}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mapa Google Maps -->
  <section class="max-w-7xl mx-auto px-6 pb-24 border-t border-[#e5e5e5] pt-16">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Ubicación</p>
    <h2 class="text-3xl md:text-4xl font-black tracking-tight mb-12 max-w-2xl">
      Estamos en
      <em class="not-italic italic text-[#FF4500]"> Providencia.</em>
    </h2>

    <div class="map-grid">
      <!-- Info textual de la ubicación -->
      <div class="map-info">
        <div class="map-info-item">
          <svg class="map-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <div>
            <p class="map-info-label">Dirección</p>
            <p class="map-info-value">Av. Holanda 099, oficina 603<br />Providencia, Santiago — Chile</p>
          </div>
        </div>

        <div class="map-info-item">
          <svg class="map-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          <div>
            <p class="map-info-label">Estacionamiento</p>
            <p class="map-info-value">Pagado en el edificio<br />Parquímetros en la calle</p>
          </div>
        </div>

        <div class="map-info-item">
          <svg class="map-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <div>
            <p class="map-info-label">Horario</p>
            <p class="map-info-value">Lunes a viernes<br />09:00 — 19:00 hrs</p>
          </div>
        </div>

        <a
          href="https://www.google.com/maps/dir/?api=1&destination=-33.418232666829546,-70.60460118861644"
          target="_blank"
          rel="noopener"
          class="map-cta"
        >
          Cómo llegar
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>

      <!-- Mapa -->
      <div class="map-iframe-wrap">
        <iframe
          title="Mapa de ubicación de DAR2 Servicios Audiovisuales en Av. Holanda 099, Providencia"
          src="https://maps.google.com/maps?q=-33.418232666829546,-70.60460118861644&t=&z=17&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen={false}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  <style>
    .map-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 32px;
      max-width: 1100px;
    }
    @media (min-width: 768px) {
      .map-grid {
        grid-template-columns: 320px 1fr;
        gap: 40px;
        align-items: stretch;
      }
    }

    .map-info {
      display: flex;
      flex-direction: column;
      gap: 28px;
    }

    .map-info-item {
      display: flex;
      gap: 14px;
      align-items: flex-start;
    }

    .map-icon {
      width: 22px;
      height: 22px;
      flex-shrink: 0;
      color: #FF4500;
      margin-top: 2px;
    }

    .map-info-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #666;
      margin: 0 0 4px;
    }

    .map-info-value {
      font-size: 15px;
      font-weight: 500;
      color: #1a1a1a;
      line-height: 1.5;
      margin: 0;
    }

    .map-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #1a1a1a;
      color: #fff;
      font-size: 14px;
      font-weight: 700;
      padding: 12px 20px;
      border-radius: 10px;
      text-decoration: none;
      transition: background 0.2s ease;
      align-self: flex-start;
      margin-top: 4px;
    }

    .map-cta:hover {
      background: #333;
    }

    .map-iframe-wrap {
      border-radius: 16px;
      overflow: hidden;
      background: #eaeaea;
      aspect-ratio: 4 / 3;
      min-height: 320px;
    }
    @media (min-width: 768px) {
      .map-iframe-wrap {
        aspect-ratio: auto;
        min-height: 360px;
      }
    }

    /* Estado del formulario tras submit */
    .contact-status {
      margin-top: 1rem;
      padding: 14px 18px;
      border-radius: 8px;
      font-size: 14px;
      line-height: 1.5;
      font-weight: 500;
    }
    .contact-status--loading {
      background: #f5f5f5;
      color: #555;
      border-left: 3px solid #999;
    }
    .contact-status--success {
      background: #ecfdf5;
      color: #065f46;
      border-left: 3px solid #10b981;
    }
    .contact-status--error {
      background: #fef2f2;
      color: #991b1b;
      border-left: 3px solid #ef4444;
    }

    /* Submit btn disabled state */
    .submit-btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }
  </style>

</Base>

<script>
  // ========================================
  // FORMULARIO DE CONTACTO (Web3Forms server-side)
  // ========================================
  // Envia el lead por email a carlos@dar2.cl via Web3Forms.
  // El canal WhatsApp queda disponible solo como contacto directo
  // en la columna lateral (no automatico desde el form).
  const WEB3FORMS_KEY = '8786a10e-33d3-40a3-9f1b-6570a3a3db0c';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('contact-submit-label') as HTMLSpanElement | null;
  const statusEl = document.getElementById('contact-status') as HTMLDivElement | null;

  function showStatus(message: string, type: 'success' | 'error' | 'loading') {
    if (!statusEl) return;
    statusEl.hidden = false;
    statusEl.className = `contact-status contact-status--${type}`;
    statusEl.textContent = message;
  }

  if (form && submitBtn && submitLabel) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!form.reportValidity()) return;

      const data = new FormData(form);

      const nombre = String(data.get('nombre') ?? '').trim();
      const email = String(data.get('email') ?? '').trim();
      const telefono = String(data.get('telefono') ?? '').trim();
      const empresa = String(data.get('empresa') ?? '').trim();
      const servicio = String(data.get('servicio') ?? '').trim();
      const mensaje = String(data.get('mensaje') ?? '').trim();

      const nombresServicio: Record<string, string> = {
        'streaming': 'Streaming',
        'live-shopping': 'Live Shopping',
        'circuito-cerrado': 'Circuito Cerrado (CCTV)',
        'estudio-virtual': 'Estudio Virtual',
        'videos-corporativos': 'Videos Corporativos',
        'estrategias-digitales': 'Estrategias Digitales',
        'redes-sociales': 'Redes Sociales',
        'filtros-ar': 'Filtros AR',
        'otro': 'Otro',
      };
      const servicioLegible = nombresServicio[servicio] ?? servicio;

      // Loading state
      submitBtn.disabled = true;
      submitLabel.textContent = 'Enviando...';
      showStatus('Enviando tu mensaje...', 'loading');

      try {
        const payload = {
          access_key: WEB3FORMS_KEY,
          subject: `Nuevo lead dar2.cl — ${servicioLegible}`,
          from_name: `${nombre} · vía dar2.cl`,
          // Reply-to: cuando Carlos responda al email, va directo al cliente
          replyto: email,
          nombre,
          email,
          telefono: telefono || '—',
          empresa: empresa || '—',
          servicio_interes: servicioLegible,
          mensaje,
        };
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          showStatus('✓ Mensaje enviado correctamente. Te responderemos en menos de 48h hábiles. Si necesitas respuesta más rápida, escríbenos por WhatsApp.', 'success');
          form.reset();
        } else {
          throw new Error(`HTTP ${res.status}`);
        }
      } catch (err) {
        console.warn('Error enviando formulario:', err);
        showStatus('Hubo un problema al enviar. Por favor escríbenos directamente a dar2@dar2.cl o por WhatsApp al +56 9 9843 3346', 'error');
      }

      submitBtn.disabled = false;
      submitLabel.textContent = 'Enviar mensaje';
    });
  }
</script>
