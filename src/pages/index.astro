<script>
  const words = [
    'live shopping',
    'streaming',
    'videos corporativos',
    'multicámara para eventos',
    'estudio virtual',
    'estrategias digitales',
    'contenido para marcas',
  ];
  let index = 0;

  function initRotatingWord() {
    const el = document.getElementById('rotating-word');
    if (!el) return;

    setInterval(() => {
      el.style.opacity = '0';
      setTimeout(() => {
        index = (index + 1) % words.length;
        el.textContent = words[index];
        el.style.opacity = '1';
      }, 200);
    }, 1800);
  }

  document.addEventListener('astro:page-load', initRotatingWord);
  initRotatingWord();

  // Hero gallery: randomize on every visit (SSG builds static, JS shuffles client-side)
  const heroPool = [
    'pc-factory.png','pc-factory-ram.png','polpaico.png',
    'beneficios-CMPC.png','valores-castano.png','copec.png',
    'habitat-2.png','vida-camara.png','march2.png','abcdin4.png',
  ];

  function initHeroGallery() {
    const imgs = document.querySelectorAll('.hero-img');
    if (!imgs.length) return;
    const shuffled = [...heroPool].sort(() => 0.5 - Math.random());
    imgs.forEach((img, i) => {
      const file = shuffled[i];
      const webpFile = file.replace(/\.(png|jpe?g)$/i, '.webp');
      const avifFile = file.replace(/\.(png|jpe?g)$/i, '.avif');
      // Picture.astro genera <picture> con <source avif>, <source webp>, <img>.
      // Hay que actualizar AMBOS sources, no solo el primero (bug previo).
      const picture = img.parentElement;
      if (picture && picture.tagName === 'PICTURE') {
        picture.querySelectorAll('source').forEach(s => {
          if (s.type === 'image/avif') s.srcset = `/images/portafolio/${avifFile}`;
          else if (s.type === 'image/webp') s.srcset = `/images/portafolio/${webpFile}`;
        });
      }
      img.src = `/images/portafolio/${file}`;
    });
  }

  document.addEventListener('astro:page-load', initHeroGallery);
  initHeroGallery();

</script>

