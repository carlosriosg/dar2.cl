---
import Base from '../layouts/Base.astro';
import VideoCard from '../components/VideoCard.astro';
import Picture from '../components/Picture.astro';
import { getCollection } from 'astro:content';
import { readdirSync } from 'node:fs';
import { join } from 'node:path';
import { servicios } from '../data/servicios.js';

// ========================================
// FEED DE INSTAGRAM (Behold.so, auto-actualiza)
// ========================================
// Cuando publicas en @dar2.cl, Behold lo recoge automaticamente.
// Si necesitas cambiar el feed-id, edita el atributo del <behold-widget> abajo.
const BEHOLD_FEED_ID = 'L5VGbKK8n3XzIZpmneCs';

const todosLosItems = await getCollection('portafolio');
const destacados = todosLosItems
  .filter(i => i.data.destacado)
  .sort((a, b) => b.data.anio - a.data.anio)
  .slice(0, 6);

// Hero gallery: 4 static initial images (client script randomizes on each visit).
// El alt text describe cada proyecto real para SEO de imágenes.
const heroPool = [
  'pc-factory.png','pc-factory-ram.png','polpaico.png',
  'beneficios-CMPC.png','valores-castano.png','copec.png',
  'habitat-2.png','vida-camara.png','march2.png','abcdin4.png',
];
const heroImages = heroPool.slice(0, 4);
const heroAltMap = {
  'pc-factory.png': 'Proyecto PC Factory — videos corporativos producidos por DAR2',
  'pc-factory-ram.png': 'Proyecto PC Factory RAM — campaña audiovisual por DAR2',
  'polpaico.png': 'Proyecto Polpaico — video corporativo de diversidad e inclusión',
  'beneficios-CMPC.png': 'Proyecto CMPC — video de beneficios corporativos por DAR2',
  'valores-castano.png': 'Proyecto Castaño — video de valores corporativos por DAR2',
  'copec.png': 'Proyecto Empresas Copec — video corporativo Q1 producido por DAR2',
  'habitat-2.png': 'Proyecto AFP Habitat — portal de formación audiovisual por DAR2',
  'vida-camara.png': 'Proyecto Vida Cámara — video institucional producido por DAR2',
  'march2.png': 'Proyecto Marsh — video de pilares corporativos por DAR2',
  'abcdin4.png': 'Proyecto ABCDIN — videos corporativos producidos por DAR2',
};

// Load client logos dynamically from public/images/clientes/
const logosDir  = join(process.cwd(), 'public', 'images', 'clientes');
const logoFiles = readdirSync(logosDir)
  .filter(f => /\.(png|jpg|jpeg|svg)$/i.test(f))
  .sort();

// Map filename -> official URL for each client (for SEO context and UX)
const clienteUrls: Record<string, string> = {
  'abcdin.png': 'https://www.abcdin.cl',
  'aconcagua.png': 'https://www.aconcagua.cl',
  'aga.png': 'https://www.aga.cl',
  'anasac.png': 'https://www.anasac.cl',
  'banco-de-chile.png': 'https://www.bancochile.cl',
  'cencosud.png': 'https://www.cencosud.com',
  'chilealimentos.png': 'https://www.chilealimentos.com',
  'clinica-santa-maria.png': 'https://www.clinicasantamaria.cl',
  'cnc.png': 'https://www.cnc.cl',
  'codelco.png': 'https://www.codelco.com',
  'consorcio.png': 'https://www.consorcio.cl',
  'copeuch.png': 'https://www.coopeuch.cl',
  'cuprum.png': 'https://www.cuprum.cl',
  'dhl.png': 'https://www.dhl.com/cl-es',
  'dijon.png': 'https://www.dijon.cl',
  'easy.png': 'https://www.easy.cl',
  'empresas-copec.png': 'https://www.empresascopec.cl',
  'enap.png': 'https://www.enap.cl',
  'enel.png': 'https://www.enel.cl',
  'engage.png': 'https://engagechile.cl',
  'euroamerica.png': 'https://www.euroamerica.cl',
  'gerdau-aza.png': 'https://www.gerdau.cl',
  'habitat.png': 'https://www.afphabitat.cl',
  'icare.png': 'https://www.icare.cl',
  'johnson.png': 'https://www.johnson.cl',
  'lp.png': 'https://www.lpchile.cl',
  'marine-harvest.png': 'https://mowi.com',
  'metlife.png': 'https://w3.metlife.cl',
  'nestle.png': 'https://www.nestle.cl',
  'nunoa.png': 'https://www.nunoa.cl',
  'paris.png': 'https://www.paris.cl',
  'parque-arauco.png': 'https://www.parauco.com',
  'pc-factory.png': 'https://www.pcfactory.cl',
  'saab.png': 'https://www.saab.com',
  'sacyr.png': 'https://www.sacyr.com',
  'salfa-corp.png': 'https://www.salfacorp.com',
  'teatro-del-lago.png': 'https://www.teatrodellago.cl',
  'ucm.png': 'https://www.ucm.cl',
  'udp.png': 'https://www.udp.cl',
};
---

<Base
  title="Productora audiovisual en Santiago de Chile — 15 años"
  description="Productora audiovisual en Chile especializada en streaming, live shopping, videos corporativos, estudio virtual y filtros AR. Más de 15 años trabajando con Cencosud, ENAP, Clínica Santa María, ABCDIN y más."
  preloadImage={`/images/portafolio/${heroImages[0].replace(/\.(png|jpe?g)$/i, '.webp')}`}
>

  <!-- ── 1. HERO ─────────────────────────────────────────── -->
  <section class="max-w-7xl mx-auto px-6 pt-16 md:pt-[80px] pb-[60px]">
    <div class="hero-grid">

      <!-- Text column -->
      <div class="hero-text">
        <h1 class="font-black leading-[1.05] tracking-tight mb-8">
          <span class="block text-lg md:text-xl text-[#666] font-semibold mb-4 tracking-normal">
            Productora audiovisual en Santiago.
          </span>
          <span
            class="block"
            style="font-size: clamp(40px, 4.5vw, 64px); letter-spacing: -1.5px; min-height: 4em;"
          >
            Producimos<br /><span
              id="rotating-word"
              style="color:#E63E00;font-style:italic;opacity:1;transition:opacity 0.2s ease;"
            >live shopping</span><br />y mucho más.
          </span>
        </h1>
        <p class="text-base md:text-lg text-[#666] leading-relaxed mb-10">
          Productora audiovisual con 15 años de experiencia. 8 servicios bajo un solo techo, una sola factura: streaming, live shopping, multicámara para eventos, estudio virtual, videos corporativos, estrategias digitales, redes sociales y filtros AR.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/contacto/"
            class="inline-flex items-center bg-[#1a1a1a] text-white text-sm font-semibold px-6 py-3 rounded-xl hover:bg-[#333] transition-colors"
          >
            Cotizar ahora
          </a>
          <a
            href="/portafolio/"
            class="inline-flex items-center text-sm font-semibold px-6 py-3 rounded-xl border border-[#e5e5e5] hover:border-[#1a1a1a] transition-colors"
          >
            Ver portafolio
          </a>
        </div>
      </div>

      <!-- Gallery column: 2×2 grid, randomized per visit via client script -->
      <div class="hero-gallery">
        {heroImages.map((img, i) => (
          <div class="hero-img-cell">
            <Picture
              src={`/images/portafolio/${img}`}
              alt={heroAltMap[img] ?? 'Proyecto audiovisual producido por DAR2'}
              class="hero-img"
              width="600"
              height="600"
              loading="eager"
              decoding={i === 0 ? 'sync' : 'async'}
              fetchpriority={i === 0 ? 'high' : undefined}
            />
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ── 2. SERVICIOS (8) ──────────────────────────────── -->
  <section class="max-w-7xl mx-auto px-6 py-16 border-t border-[#e5e5e5]">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-3">Servicios</p>
    <h2 class="text-3xl md:text-4xl font-black tracking-tight leading-tight mb-6">
      8 servicios. Un solo proveedor.
    </h2>
    <p class="text-base md:text-lg text-[#666] leading-relaxed max-w-3xl mb-10">
      Desde streaming corporativo en vivo hasta filtros AR para Instagram. Equipo propio, postproducción interna y una sola factura por todo el proyecto. Sin coordinar 5 proveedores. Sin sorpresas en el presupuesto.
    </p>

    <div class="home-svc-grid">
      {servicios.map((s) => (
          <a
            href={`/servicios/${s.slug}/`}
            class={`home-svc-card${s.featured ? ' home-svc-dark' : ''}`}
          >
            {s.featured && <span class="home-svc-badge">{s.badgeText ?? 'TENDENCIA'}</span>}
            <div class="home-svc-img">
              <div class="home-svc-img-inner">
                <Picture
                  src={`/images/servicios/${s.slug}-card.jpg`}
                  alt={s.title}
                  width="730"
                  height="544"
                  class="w-full h-full object-cover"
                  loading="lazy"
                  responsive
                  sizes="(max-width: 640px) 95vw, (max-width: 1024px) 45vw, 365px"
                />
              </div>
            </div>
            <div class="home-svc-text">
              <p class="home-svc-num">{s.num}</p>
              <p class="home-svc-title">{s.title}</p>
              <p class="home-svc-desc">{s.shortDesc}</p>
            </div>
          </a>
      ))}
    </div>

    <div class="mt-8 text-center">
      <a href="/servicios/" class="outline-btn">
        Ver todos los servicios →
      </a>
    </div>
  </section>

  <!-- ── 3. PROYECTOS DESTACADOS ───────────────────────── -->
  {destacados.length > 0 && (
    <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
      <div class="flex items-end justify-between mb-4 flex-wrap gap-4">
        <p class="text-xs font-semibold uppercase tracking-widest text-[#666]">Portafolio</p>
        <a
          href="/portafolio/"
          class="text-sm font-semibold text-[#666] hover:text-[#1a1a1a] transition-colors whitespace-nowrap"
        >
          Ver todos los proyectos →
        </a>
      </div>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight leading-tight mb-6">
        Trabajo real,<br />clientes reales.
      </h2>
      <p class="text-base md:text-lg text-[#666] leading-relaxed max-w-3xl mb-12">
        Cirugías robóticas transmitidas en vivo para Clínica Santa María, junta anual de accionistas para Empresas Copec, videos de cultura organizacional para Polpaico y CMPC, portal de formación para AFP Habitat. Cada caso producido por nuestro equipo, dirigido por nuestro director, entregado en plazo.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
        {destacados.map(item => (
          <VideoCard
            youtube_url={item.data.youtube_url}
            titulo={item.data.titulo}
            cliente={item.data.cliente}
            thumbnail={item.data.thumbnail}
          />
        ))}
      </div>
      <div class="mt-10 text-center">
        <a href="/portafolio/" class="outline-btn">
          Ver todos los proyectos ({todosLosItems.length}) →
        </a>
      </div>
    </section>
  )}

  <!-- ── 4. CONFÍAN EN NOSOTROS (marquesina infinita) ────────────────────────── -->
  <section class="clientes-section border-t border-[#e5e5e5] py-20">
    <div class="max-w-[1200px] mx-auto px-6 mb-12">
      <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Clientes</p>
      <h2 class="text-3xl md:text-4xl font-black tracking-tight">
        Confían en nosotros.
      </h2>
    </div>

    <!-- Marquesina: contenedor full-width con overflow hidden -->
    <div class="marquee" aria-label="Clientes de DAR2">
      <!-- Track duplicado 2x para loop infinito sin saltos -->
      <div class="marquee-track">
        {logoFiles.map(file => {
          const name = file.replace(/\.(png|jpg|jpeg|webp|svg)$/i, '').replace(/-/g, ' ');
          const url = clienteUrls[file];
          const src = `/images/clientes/${file}`;
          return (
            <div class="marquee-item">
              {url ? (
                <a
                  href={url}
                  target="_blank"
                  rel="noopener"
                  aria-label={`Visitar sitio web de ${name}`}
                  title={name}
                >
                  <Picture src={src} alt={`Logo ${name}`} width="200" height="80" loading="lazy" decoding="async" />
                </a>
              ) : (
                <div title={name}>
                  <Picture src={src} alt={`Logo ${name}`} width="200" height="80" loading="lazy" decoding="async" />
                </div>
              )}
            </div>
          );
        })}
        {logoFiles.map(file => {
          const name = file.replace(/\.(png|jpg|jpeg|webp|svg)$/i, '').replace(/-/g, ' ');
          const url = clienteUrls[file];
          const src = `/images/clientes/${file}`;
          return (
            <div class="marquee-item" aria-hidden="true">
              {url ? (
                <a href={url} target="_blank" rel="noopener" tabindex="-1" title={name}>
                  <Picture src={src} alt={`Logo ${name}`} width="200" height="80" loading="lazy" decoding="async" />
                </a>
              ) : (
                <div title={name}>
                  <Picture src={src} alt={`Logo ${name}`} width="200" height="80" loading="lazy" decoding="async" />
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ── 4B. TESTIMONIALES ─────────────────────────────── -->
  <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Testimonios</p>
    <h2 class="text-3xl md:text-4xl font-black tracking-tight mb-12 max-w-2xl">
      Lo que dicen quienes ya trabajaron con DAR2.
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <blockquote class="testimonial">
        <p class="testimonial-text">
          "DAR2 produjo nuestra junta anual durante varios años seguidos. Cero interrupciones, cero excusas. Cuando una marca te pide eso, los recomendamos antes que cualquier otro."
        </p>
        <footer class="testimonial-meta">
          <p class="testimonial-role">Gerente de Comunicaciones</p>
          <p class="testimonial-org">Retail multinacional, Chile</p>
        </footer>
      </blockquote>
      <blockquote class="testimonial">
        <p class="testimonial-text">
          "Pasamos de hacer videos en Zoom con el celular del jefe a contenido broadcast con escenografía virtual. La diferencia en percepción de marca con nuestros afiliados fue inmediata."
        </p>
        <footer class="testimonial-meta">
          <p class="testimonial-role">Directora de Marketing Digital</p>
          <p class="testimonial-org">AFP, Chile</p>
        </footer>
      </blockquote>
      <blockquote class="testimonial">
        <p class="testimonial-text">
          "Nuestro primer live shopping convirtió varias veces mejor que el e-commerce normal. Ahora hacemos uno cada dos semanas. DAR2 ya nos ha producido decenas de sesiones."
        </p>
        <footer class="testimonial-meta">
          <p class="testimonial-role">Jefe de Activaciones</p>
          <p class="testimonial-org">Retail farmacéutico, Chile</p>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- ── 5. STATS ──────────────────────────────────────── -->
  <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">En números</p>
    <h2 class="text-3xl md:text-4xl font-black tracking-tight mb-6 max-w-xl">
      Trayectoria que respalda cada proyecto.
    </h2>
    <p class="text-base md:text-lg text-[#666] leading-relaxed max-w-3xl mb-12">
      Fundada en 2010 por Carlos Rios Guevara. 15 años produciendo audiovisual para empresas chilenas con equipo propio y postproducción interna. Las cifras hablan por nosotros.
    </p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-4">
      <div class="border-l-2 border-[#FF4500] pl-6">
        <p class="text-5xl font-black tracking-tight">15+</p>
        <p class="text-[#666] text-sm mt-2 leading-snug">Años de<br />experiencia</p>
      </div>
      <div class="border-l-2 border-[#e5e5e5] pl-6">
        <p class="text-5xl font-black tracking-tight">40+</p>
        <p class="text-[#666] text-sm mt-2 leading-snug">Transmisiones<br />al año</p>
      </div>
      <div class="border-l-2 border-[#e5e5e5] pl-6">
        <p class="text-5xl font-black tracking-tight">30+</p>
        <p class="text-[#666] text-sm mt-2 leading-snug">Clientes<br />corporativos</p>
      </div>
      <div class="border-l-2 border-[#e5e5e5] pl-6">
        <p class="text-5xl font-black tracking-tight">48h</p>
        <p class="text-[#666] text-sm mt-2 leading-snug">Respuesta a<br />cotización</p>
      </div>
    </div>
  </section>

  <!-- ── 5B. CÓMO TRABAJAMOS ───────────────────────────── -->
  <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Proceso</p>
    <h2 class="text-3xl md:text-4xl font-black tracking-tight mb-12 max-w-2xl">
      Cómo trabajamos.
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div class="process-step">
        <p class="process-num">01</p>
        <h3 class="process-title">Briefing y propuesta</h3>
        <p class="process-desc">
          Una reunión inicial para entender qué necesitas: tipo de evento, audiencia, formato, presupuesto. Te enviamos una propuesta detallada y la cotización en menos de 48 horas hábiles, sin letra chica.
        </p>
      </div>
      <div class="process-step">
        <p class="process-num">02</p>
        <h3 class="process-title">Producción</h3>
        <p class="process-desc">
          Coordinamos todo el rodaje o transmisión: equipo técnico, dirección, cámaras, sonido, iluminación, gráfica en tiempo real y enlace redundante. Un solo equipo, un solo director responsable. Tú revisas avances en cada hito.
        </p>
      </div>
      <div class="process-step">
        <p class="process-num">03</p>
        <h3 class="process-title">Entrega y postproducción</h3>
        <p class="process-desc">
          Edición, corrección de color, motion graphics y audio mastering. Entregamos en todos los formatos que necesites: redes sociales, web, presentaciones internas, archivo broadcast. Una sola factura.
        </p>
      </div>
    </div>
  </section>

  <!-- ── 6. CTA FINAL ──────────────────────────────────── -->
  <section class="bg-[#1a1a1a] mt-8">
    <div class="max-w-7xl mx-auto px-6 py-24 flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-[#aaa] mb-4">
          ¿Listo para transmitir?
        </p>
        <h2 class="text-3xl md:text-4xl font-black tracking-tight text-white leading-tight mb-3">
          Cotización a medida en 48h.
        </h2>
        <p class="text-[#ccc] text-base md:text-lg">Sin letra chica. Sin intermediarios.</p>
      </div>
      <div class="shrink-0 flex flex-col items-start md:items-end gap-3">
        <a href="/contacto/" class="cta-outline-btn">
          Contáctanos →
        </a>
        <a href="mailto:dar2@dar2.cl" class="text-[#ccc] text-[13px] hover:text-white transition-colors">
          o escríbenos a dar2@dar2.cl
        </a>
      </div>
    </div>
  </section>

  <!-- INSTAGRAM FEED -->
  <section class="ig-section" aria-labelledby="ig-heading">
    <div class="ig-container">

      <div class="ig-header">
        <div class="ig-header-text">
          <p class="ig-eyebrow">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.336 3.608 1.311.975.975 1.249 2.242 1.311 3.608.058 1.266.069 1.646.069 4.85s-.012 3.584-.07 4.85c-.062 1.366-.336 2.633-1.311 3.608-.975.975-2.242 1.249-3.608 1.311-1.266.058-1.646.069-4.85.069s-3.584-.012-4.85-.07c-1.366-.062-2.633-.336-3.608-1.311-.975-.975-1.249-2.242-1.311-3.608C2.175 15.647 2.163 15.267 2.163 12s.012-3.584.07-4.85c.062-1.366.336-2.633 1.311-3.608.975-.975 2.242-1.249 3.608-1.311C8.416 2.175 8.796 2.163 12 2.163zm0 1.622c-3.141 0-3.505.012-4.737.069-1.05.048-1.62.222-2 .369-.5.195-.857.428-1.232.803-.375.375-.608.732-.803 1.232-.147.38-.32.95-.369 2-.057 1.232-.069 1.596-.069 4.737s.012 3.505.069 4.737c.048 1.05.222 1.62.369 2 .195.5.428.857.803 1.232.375.375.732.608 1.232.803.38.147.95.32 2 .369 1.232.057 1.596.069 4.737.069s3.505-.012 4.737-.069c1.05-.048 1.62-.222 2-.369.5-.195.857-.428 1.232-.803.375-.375.608-.732.803-1.232.147-.38.32-.95.369-2 .057-1.232.069-1.596.069-4.737s-.012-3.505-.069-4.737c-.048-1.05-.222-1.62-.369-2-.195-.5-.428-.857-.803-1.232-.375-.375-.732-.608-1.232-.803-.38-.147-.95-.32-2-.369-1.232-.057-1.596-.069-4.737-.069zm0 2.756a5.459 5.459 0 1 1 0 10.918 5.459 5.459 0 0 1 0-10.918zm0 9.005a3.546 3.546 0 1 0 0-7.092 3.546 3.546 0 0 0 0 7.092zm6.95-9.218a1.275 1.275 0 1 1-2.55 0 1.275 1.275 0 0 1 2.55 0z"/>
            </svg>
            <span>@dar2.cl · Instagram</span>
          </p>
          <h2 id="ig-heading" class="ig-title">
            Detrás de cámaras del <em class="not-italic italic text-[#FF4500]">estudio.</em>
          </h2>
          <p class="ig-subtitle">
            Producciones recientes, behind the scenes y novedades del día a día en DAR2.
          </p>
        </div>
        <a
          href="https://www.instagram.com/dar2.cl/"
          target="_blank"
          rel="noopener"
          class="ig-follow-btn"
          aria-label="Seguir a DAR2 en Instagram"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
