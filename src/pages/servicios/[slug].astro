---
import Base from '../../layouts/Base.astro';
import VideoCard from '../../components/VideoCard.astro';
import Picture from '../../components/Picture.astro';
import { servicios } from '../../data/servicios.js';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return servicios
    .filter(s => s.slug !== 'filtros-ar')
    .map(s => ({
      params: { slug: s.slug },
      props: { servicio: s },
    }));
}

const { servicio: s } = Astro.props;

// Map slug → tipo field in portafolio .md files
const slugToTipo = {
  'videos-corporativos': 'corporativo',
};
const tipo = slugToTipo[s.slug] ?? s.slug;

const portafolio = await getCollection('portafolio');

// Target: 6 items in the DOM for good shuffle variety
const TARGET = 6;

const propios = portafolio
  .filter(item => item.data.tipo === tipo)
  .sort((a, b) => b.data.anio - a.data.anio);

const otros = portafolio
  .filter(item => item.data.tipo !== tipo)
  .sort((a, b) => b.data.anio - a.data.anio);

// Fill up to TARGET with other-type items if needed
const relacionados = [
  ...propios,
  ...otros.slice(0, Math.max(0, TARGET - propios.length)),
].slice(0, TARGET);

const serviceJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: s.title,
  provider: { '@id': 'https://dar2.cl/#organization' },
  areaServed: 'Chile',
  description: s.seoDescription ?? s.description,
  serviceType: s.serviceType ?? s.title,
});

const faqJsonLd = s.faqs ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: s.faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
}) : null;

const breadcrumbs = [
  { name: 'Inicio', url: 'https://dar2.cl/' },
  { name: 'Servicios', url: 'https://dar2.cl/servicios/' },
  { name: s.title, url: `https://dar2.cl/servicios/${s.slug}/` },
];

// Cross-linking: 3 servicios relacionados por cada uno (mejora crawl depth + SEO).
const relacionadosMap = {
  'streaming': ['live-shopping', 'circuito-cerrado', 'estudio-virtual'],
  'live-shopping': ['streaming', 'videos-corporativos', 'redes-sociales'],
  'circuito-cerrado': ['streaming', 'estudio-virtual', 'videos-corporativos'],
  'estudio-virtual': ['streaming', 'videos-corporativos', 'filtros-ar'],
  'videos-corporativos': ['estudio-virtual', 'redes-sociales', 'estrategias-digitales'],
  'estrategias-digitales': ['redes-sociales', 'videos-corporativos', 'filtros-ar'],
  'redes-sociales': ['videos-corporativos', 'filtros-ar', 'estrategias-digitales'],
};
const relacionadosSlugs = relacionadosMap[s.slug] ?? [];
const serviciosRelacionados = relacionadosSlugs
  .map(slug => servicios.find(x => x.slug === slug))
  .filter(Boolean);
---

<Base
  title={s.seoTitle ?? s.title}
  description={s.seoDescription ?? s.description}
  breadcrumbs={breadcrumbs}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={serviceJsonLd} />
    {faqJsonLd && <script type="application/ld+json" set:html={faqJsonLd} />}
  </Fragment>

  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-6 pt-16 md:pt-24 pb-16">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-6">
      {s.heroEyebrow ?? `${s.num} — ${s.title}`}
    </p>
    <h1 class="text-5xl md:text-6xl font-black tracking-tight leading-[1.05] mb-6 max-w-3xl" set:html={s.tagline}></h1>
    <p class="text-lg text-[#666] max-w-xl leading-relaxed mb-8">
      {s.description}
    </p>
    <a
      href={`/contacto?servicio=${s.slug}`}
      class="inline-flex items-center bg-[#1a1a1a] text-white text-sm font-semibold px-6 py-3 rounded-xl hover:bg-[#333] transition-colors"
    >
      Cotizar {s.title} →
    </a>
  </section>

  <!-- ¿Qué incluye? + Imagen -->
  <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-2xl font-black tracking-tight mb-8">¿Qué incluye?</h2>
        <ul class="space-y-4">
          {s.bullets.map(item => (
            <li class="flex items-start gap-3">
              <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-[#FF4500]"></span>
              <p class="text-[#444] leading-relaxed">{item}</p>
            </li>
          ))}
        </ul>
        <a
          href={`/contacto?servicio=${s.slug}`}
          class="mt-10 inline-flex items-center bg-[#FF4500] text-white text-sm font-semibold px-6 py-3 rounded-xl hover:bg-[#e03d00] transition-colors"
        >
          Cotizar {s.title} →
        </a>
      </div>
      <div class="rounded-[16px] overflow-hidden aspect-video bg-[#eaeaea]">
        <Picture
          src={`/images/servicios/${s.slug}.jpg`}
          alt={`${s.title} — DAR2 Servicios Audiovisuales`}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Por qué te conviene -->
  {s.benefits && s.benefits.length > 0 && (
    <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
      <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Ventajas</p>
      <h2 class="text-3xl font-black tracking-tight mb-12">Por qué te conviene.</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {s.benefits.map(b => (
          <div>
            <p class="svc-benefit-num">{b.num}</p>
            <p class="text-lg font-bold text-[#111] mb-2">{b.title}</p>
            <p class="text-[#666] text-sm leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Casos de uso -->
  {s.cases && s.cases.length > 0 && (
    <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
      <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Aplicaciones</p>
      <h2 class="text-3xl font-black tracking-tight mb-12">Casos de uso.</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {s.cases.map(c => (
          <div class="svc-case-card">
            <p class="svc-case-num">{c.num}</p>
            <p class="svc-case-label">{c.label}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Trabajo reciente (random por visita) -->
  {relacionados.length > 0 && (
    <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
      <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Portafolio</p>
      <h2 class="text-3xl font-black tracking-tight mb-10">Trabajo reciente.</h2>
      <div id="portafolio-random" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
        {relacionados.map(item => (
          <VideoCard
            youtube_url={item.data.youtube_url}
            titulo={item.data.titulo}
            cliente={item.data.cliente}
            thumbnail={item.data.thumbnail}
          />
        ))}
      </div>
      <div class="mt-10">
        <a href="/portafolio/" class="text-sm font-semibold text-[#666] hover:text-[#1a1a1a] transition-colors">
          Ver todo el portafolio →
        </a>
      </div>
    </section>
  )}

  <!-- FAQ -->
  {s.faqs && s.faqs.length > 0 && (
    <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
      <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">FAQ</p>
      <h2 class="text-3xl font-black tracking-tight mb-10">Preguntas frecuentes.</h2>
      <div class="faq-list">
        {s.faqs.map(f => (
          <details class="faq-item">
            <summary class="faq-question">{f.q}</summary>
            <p class="faq-answer">{f.a}</p>
          </details>
        ))}
      </div>
    </section>
  )}

  <!-- Servicios relacionados -->
  {serviciosRelacionados.length > 0 && (
    <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
      <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Servicios relacionados</p>
      <h2 class="text-3xl font-black tracking-tight mb-10">
        ¿Te puede interesar también?
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {serviciosRelacionados.map(rel => (
          <a
            href={`/servicios/${rel.slug}/`}
            class="block p-6 border border-[#e5e5e5] rounded-xl hover:border-[#1a1a1a] transition-colors"
          >
            <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-2">{rel.num}</p>
            <h3 class="text-xl font-black tracking-tight mb-2">{rel.title}</h3>
            <p class="text-sm text-[#666] leading-relaxed">{rel.shortDesc}</p>
            <p class="text-sm font-semibold text-[#FF4500] mt-4">Ver servicio →</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- CTA final -->
  <section class="bg-[#1a1a1a] mt-8">
    <div class="max-w-7xl mx-auto px-6 py-20 flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <h2 class="text-3xl md:text-4xl font-black tracking-tight text-white mb-3">
          {s.ctaTitle ?? `¿Necesitas ${s.title}?`}
        </h2>
        <p class="text-[#999]">Cotización a medida en 48 horas hábiles.</p>
      </div>
      <a
        href="/contacto/"
        class="shrink-0 inline-flex items-center bg-[#FF4500] text-white text-sm font-bold px-8 py-4 rounded-xl hover:bg-[#e03d00] transition-colors whitespace-nowrap"
      >
        Contáctanos →
      </a>
    </div>
  </section>

</Base>

<style is:global>
  /* Initially hide items 4+ — JS shuffle will reassign display explicitly */
  #portafolio-random > *:nth-child(n+4) {
    display: none;
  }
</style>

<style>
  .svc-benefit-num {
    font-size: 40px;
    font-weight: 900;
    color: #FF4500;
    line-height: 1;
    margin-bottom: 12px;
    letter-spacing: -1px;
  }

  .svc-case-card {
    background: #fafafa;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    padding: 24px 20px;
  }

  .svc-case-num {
    font-size: 11px;
    font-weight: 600;
    color: #FF4500;
    letter-spacing: 2px;
    margin-bottom: 8px;
  }

  .svc-case-label {
    font-size: 15px;
    font-weight: 700;
    color: #111;
    line-height: 1.3;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid #e5e5e5;
  }

  .faq-item {
    border-bottom: 1px solid #e5e5e5;
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 20px 0;
    font-size: 16px;
    font-weight: 600;
    color: #111;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .faq-question::-webkit-details-marker { display: none; }

  .faq-question::after {
    content: '+';
    font-size: 22px;
    font-weight: 300;
    color: #999;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  details[open] .faq-question::after {
    transform: rotate(45deg);
  }

  .faq-answer {
    padding: 0 0 20px 0;
    color: #555;
    font-size: 15px;
    line-height: 1.7;
    max-width: 720px;
  }
</style>

<script>
  // Fisher-Yates shuffle — runs on every page load, shows 3 random portfolio items
  const container = document.getElementById('portafolio-random');
  if (container && container.children.length > 0) {
    const items = Array.from(container.children);

    // Fisher-Yates in-place shuffle of array
    for (let i = items.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [items[i], items[j]] = [items[j], items[i]];
    }

    // Re-append in shuffled order and explicitly set display
    items.forEach((item, idx) => {
      container.appendChild(item);           // reorder in DOM
      item.style.display = idx < 3 ? '' : 'none'; // show first 3, hide rest
    });
  }
</script>
