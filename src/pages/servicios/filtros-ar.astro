---
import Base from '../../layouts/Base.astro';
import Picture from '../../components/Picture.astro';
import { servicios } from '../../data/servicios.js';

const s = servicios.find(x => x.slug === 'filtros-ar');

const serviceJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: s.title,
  provider: { '@id': 'https://dar2.cl/#organization' },
  areaServed: 'Chile',
  description: s.seoDescription,
  serviceType: s.serviceType,
});

const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: s.faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
});

const breadcrumbs = [
  { name: 'Inicio', url: 'https://dar2.cl/' },
  { name: 'Servicios', url: 'https://dar2.cl/servicios/' },
  { name: s.title, url: `https://dar2.cl/servicios/${s.slug}/` },
];

// Servicios relacionados con filtros-ar
const serviciosRelacionados = ['redes-sociales', 'estudio-virtual', 'estrategias-digitales']
  .map(slug => servicios.find(x => x.slug === slug))
  .filter(Boolean);
---

<Base
  title={s.seoTitle}
  description={s.seoDescription}
  breadcrumbs={breadcrumbs}
  preloadImage="/images/servicios/filtros-ar.webp"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={serviceJsonLd} />
    <script type="application/ld+json" set:html={faqJsonLd} />
  </Fragment>

  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-6 pt-16 md:pt-24 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12 items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-6">
          {s.heroEyebrow}
        </p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-[1.05] mb-6" set:html={s.tagline}></h1>
        <p class="text-base md:text-lg text-[#666] leading-relaxed mb-8">
          {s.description}
        </p>
        <a
          href="/contacto?servicio=filtros-ar"
          class="inline-flex items-center bg-[#1a1a1a] text-white text-sm font-semibold px-6 py-3 rounded-xl hover:bg-[#333] transition-colors"
        >
          Cotizar Filtros AR →
        </a>
      </div>
      <div class="rounded-[16px] overflow-hidden aspect-video bg-[#eaeaea]">
        <Picture
          src="/images/servicios/filtros-ar.jpg"
          alt="Filtros AR — DAR2 Servicios Audiovisuales"
          class="w-full h-full object-cover"
          width="800"
          height="450"
          loading="eager"
          fetchpriority="high"
          decoding="sync"
        />
      </div>
    </div>
  </section>

  <!-- Long description (qué es / cómo lo hacemos / por qué importa) -->
  {s.longDescription && s.longDescription.length > 0 && (
    <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
      <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Sobre el servicio</p>
      <h2 class="text-3xl font-black tracking-tight mb-10 max-w-2xl">¿Qué es y cómo lo producimos?</h2>
      <div class="max-w-3xl space-y-6">
        {s.longDescription.map(p => (
          <p class="text-[#444] text-base md:text-lg leading-relaxed">{p}</p>
        ))}
      </div>
    </section>
  )}

  <!-- Para quién es -->
  {s.forWhom && (
    <section class="max-w-7xl mx-auto px-6 py-16 border-t border-[#e5e5e5]">
      <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Para quién</p>
      <h2 class="text-3xl font-black tracking-tight mb-6 max-w-2xl">¿Para qué tipo de empresa aplica?</h2>
      <p class="text-[#444] text-base md:text-lg leading-relaxed max-w-3xl">{s.forWhom}</p>
    </section>
  )}

  <!-- Proceso de trabajo -->
  {s.process && s.process.length > 0 && (
    <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
      <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Proceso</p>
      <h2 class="text-3xl font-black tracking-tight mb-12 max-w-2xl">Cómo trabajamos en cada proyecto.</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {s.process.map(step => (
          <div class="ar-process-step">
            <p class="ar-process-num">{step.num}</p>
            <h3 class="ar-process-title">{step.title}</h3>
            <p class="ar-process-desc">{step.desc}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- ¿Qué incluye? (full-width, bullets en 2 columnas) -->
  <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Deliverables</p>
    <h2 class="text-3xl font-black tracking-tight mb-10">¿Qué incluye?</h2>
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-4 max-w-5xl">
      {s.bullets.map(item => (
        <li class="flex items-start gap-3">
          <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-[#FF4500]"></span>
          <p class="text-[#444] leading-relaxed">{item}</p>
        </li>
      ))}
    </ul>
    <div class="mt-10">
      <a
        href="/contacto?servicio=filtros-ar"
        class="inline-flex items-center bg-[#FF4500] text-white text-sm font-semibold px-6 py-3 rounded-xl hover:bg-[#e03d00] transition-colors"
      >
        Cotizar Filtros AR →
      </a>
    </div>
  </section>

  <!-- Por qué te conviene -->
  <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Ventajas</p>
    <h2 class="text-3xl font-black tracking-tight mb-12">Por qué te conviene.</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {s.benefits.map(b => (
        <div>
          <p class="ar-benefit-num">{b.num}</p>
          <p class="text-lg font-bold text-[#111] mb-2">{b.title}</p>
          <p class="text-[#666] text-sm leading-relaxed">{b.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Casos de uso -->
  <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Aplicaciones</p>
    <h2 class="text-3xl font-black tracking-tight mb-12">Casos de uso.</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {s.cases.map(c => (
        <div class="ar-case-card">
          <p class="ar-case-num">{c.num}</p>
          <p class="ar-case-label">{c.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Proyectos placeholder -->
  <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Portafolio</p>
    <h2 class="text-3xl font-black tracking-tight mb-6">Proyectos de filtros AR.</h2>
    <p class="text-[#666] max-w-xl leading-relaxed mb-8">
      Estamos preparando nuestros primeros casos para compartir públicamente.
      ¿Quieres ser uno de los primeros? Hablemos.
    </p>
    <a
      href="/contacto/"
      class="inline-flex items-center bg-[#1a1a1a] text-white text-sm font-semibold px-6 py-3 rounded-xl hover:bg-[#333] transition-colors"
    >
      Agendar reunión →
    </a>
  </section>

  <!-- FAQ -->
  <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">FAQ</p>
    <h2 class="text-3xl font-black tracking-tight mb-10">Preguntas frecuentes.</h2>
    <div class="faq-list">
      {s.faqs.map(f => (
        <details class="faq-item">
          <summary class="faq-question">{f.q}</summary>
          <p class="faq-answer">{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- Servicios relacionados -->
  <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#e5e5e5]">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">Servicios relacionados</p>
    <h2 class="text-3xl font-black tracking-tight mb-10">¿Te puede interesar también?</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {serviciosRelacionados.map(rel => (
        <a
          href={`/servicios/${rel.slug}/`}
          class="block p-6 border border-[#e5e5e5] rounded-xl hover:border-[#1a1a1a] transition-colors"
        >
          <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-2">{rel.num}</p>
          <h3 class="text-xl font-black tracking-tight mb-2">{rel.title}</h3>
          <p class="text-sm text-[#666] leading-relaxed">{rel.shortDesc}</p>
          <p class="text-sm font-semibold text-[#FF4500] mt-4">Ver servicio →</p>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA final -->
  <section class="bg-[#1a1a1a] mt-8">
    <div class="max-w-7xl mx-auto px-6 py-20 flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <h2 class="text-3xl md:text-4xl font-black tracking-tight text-white mb-3">
          {s.ctaTitle}
        </h2>
        <p class="text-[#999]">Cotización a medida en 48h.</p>
      </div>
      <a
        href="/contacto/"
        class="shrink-0 inline-flex items-center bg-[#FF4500] text-white text-sm font-bold px-8 py-4 rounded-xl hover:bg-[#e03d00] transition-colors whitespace-nowrap"
      >
        Contáctanos →
      </a>
    </div>
  </section>

</Base>

<style>
  .ar-process-step {
    border-top: 2px solid #FF4500;
    padding-top: 16px;
  }

  .ar-process-num {
    font-size: 13px;
    font-weight: 700;
    color: #FF4500;
    letter-spacing: 0.05em;
    margin: 0 0 10px;
  }

  .ar-process-title {
    font-size: 20px;
    font-weight: 900;
    letter-spacing: -0.3px;
    line-height: 1.2;
    color: #1a1a1a;
    margin: 0 0 10px;
  }

  .ar-process-desc {
    font-size: 15px;
    line-height: 1.65;
    color: #555;
    margin: 0;
  }

  .ar-benefit-num {
    font-size: 40px;
    font-weight: 900;
    color: #FF4500;
    line-height: 1;
    margin-bottom: 12px;
    letter-spacing: -1px;
  }

  .ar-case-card {
    background: #fafafa;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    padding: 24px 20px;
  }

  .ar-case-num {
    font-size: 11px;
    font-weight: 600;
    color: #FF4500;
    letter-spacing: 2px;
    margin-bottom: 8px;
  }

  .ar-case-label {
    font-size: 15px;
    font-weight: 700;
    color: #111;
    line-height: 1.3;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid #e5e5e5;
  }

  .faq-item {
    border-bottom: 1px solid #e5e5e5;
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 20px 0;
    font-size: 16px;
    font-weight: 600;
    color: #111;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .faq-question::-webkit-details-marker { display: none; }

  .faq-question::after {
    content: '+';
    font-size: 22px;
    font-weight: 300;
    color: #999;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  details[open] .faq-question::after {
    transform: rotate(45deg);
  }

  .faq-answer {
    padding: 0 0 20px 0;
    color: #555;
    font-size: 15px;
    line-height: 1.7;
    max-width: 720px;
  }
</style>
