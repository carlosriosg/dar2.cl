---
import Base from '../../layouts/Base.astro';
import Picture from '../../components/Picture.astro';
import { servicios } from '../../data/servicios.js';

const breadcrumbs = [
  { name: 'Inicio', url: 'https://dar2.cl/' },
  { name: 'Servicios', url: 'https://dar2.cl/servicios/' },
];
---

<Base
  title="Servicios audiovisuales: streaming, live shopping y más"
  description="8 servicios audiovisuales bajo un mismo techo: streaming, live shopping, circuito cerrado, estudio virtual, videos corporativos, estrategias digitales, redes sociales y filtros AR."
  breadcrumbs={breadcrumbs}
>

  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-6 pt-16 md:pt-24 pb-16">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-6">Servicios</p>
    <h1 class="text-5xl md:text-6xl font-black tracking-tight leading-[1.05] mb-6 max-w-3xl">
      Todo lo que necesitas
      <em class="not-italic italic text-[#FF4500]"> bajo un solo techo.</em>
    </h1>
    <p class="text-lg text-[#666] max-w-2xl leading-relaxed">
      8 servicios audiovisuales especializados, equipo propio de producción y postproducción, una sola factura por todo el proyecto. Cotización a medida en 48 horas hábiles.
    </p>
  </section>

  <!-- Grilla de 8 servicios -->
  <section class="max-w-7xl mx-auto px-6 pb-24 pt-16">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-6">Catálogo completo</p>
    <div class="svc-grid-index">
      {servicios.map(s => (
        <a href={`/servicios/${s.slug}/`} class={`svc-card-index${s.featured ? ' svc-card-dark' : ''}`}>
          {s.featured && <span class="svc-badge">{s.badgeText ?? 'TENDENCIA'}</span>}
          <div class="svc-img-box">
            <Picture
              src={`/images/servicios/${s.slug}-card.jpg`}
              alt={s.title}
              width="730"
              height="544"
              class="w-full h-full object-cover"
              loading="lazy"
              responsive
              sizes="(max-width: 640px) 95vw, (max-width: 1024px) 45vw, 365px"
            />
          </div>
          <div class="svc-body">
            <p class="svc-num">{s.num}</p>
            <p class="svc-title">{s.title}</p>
            <p class="svc-desc">{s.shortDesc}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Intro: por qué un solo proveedor -->
  <section class="max-w-7xl mx-auto px-6 py-16 border-t border-[#e5e5e5]">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-5xl">
      <div>
        <h2 class="text-3xl font-black tracking-tight mb-6">Un solo equipo de extremo a extremo.</h2>
        <p class="text-[#666] leading-relaxed mb-4">
          La producción audiovisual corporativa típica implica coordinar entre productora, técnicos, postproducción, gráfica y agencias separadas. El cliente termina haciendo de project manager y pagando por las brechas entre todos los proveedores.
        </p>
        <p class="text-[#666] leading-relaxed">
          En DAR2 operamos los 8 servicios con equipo interno: cámaras Sony FX6, switchers, sistema de iluminación broadcast, multicámaras robóticas PTZ, estudio con green screen y enlaces redundantes. La producción y la postproducción viven en el mismo edificio. Un solo director de proyecto coordina todo.
        </p>
      </div>
      <div>
        <h2 class="text-3xl font-black tracking-tight mb-6">¿Qué servicio necesitas?</h2>
        <p class="text-[#666] leading-relaxed mb-4">
          Si tienes un evento corporativo en vivo (junta anual, lanzamiento, seminario) → <a href="/servicios/streaming/" class="svc-inline-link">Streaming</a>. Si vendes online y quieres ventas en vivo → <a href="/servicios/live-shopping/" class="svc-inline-link">Live Shopping</a>. Si necesitas video institucional o de cultura → <a href="/servicios/videos-corporativos/" class="svc-inline-link">Videos Corporativos</a>.
        </p>
        <p class="text-[#666] leading-relaxed">
          Si requieres contenido recurrente para redes → <a href="/servicios/redes-sociales/" class="svc-inline-link">Redes Sociales</a> o <a href="/servicios/estrategias-digitales/" class="svc-inline-link">Estrategias Digitales</a>. Para contenido broadcast con escenografía digital → <a href="/servicios/estudio-virtual/" class="svc-inline-link">Estudio Virtual</a>. Para activación viral en redes → <a href="/servicios/filtros-ar/" class="svc-inline-link">Filtros AR</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#1a1a1a]">
    <div class="max-w-7xl mx-auto px-6 py-20 flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <h2 class="text-3xl md:text-4xl font-black tracking-tight text-white mb-3">
          Cotización a medida en 48h.
        </h2>
        <p class="text-[#ccc]">Cuéntanos tu proyecto y te armamos una propuesta.</p>
      </div>
      <a
        href="/contacto/"
        class="shrink-0 inline-flex items-center bg-[#FF4500] text-white text-sm font-bold px-8 py-4 rounded-xl hover:bg-[#e03d00] transition-colors whitespace-nowrap"
      >
        Contáctanos →
      </a>
    </div>
  </section>

</Base>

<style>
  .svc-grid-index {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 640px)  { .svc-grid-index { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .svc-grid-index { grid-template-columns: repeat(3, 1fr); } }

  .svc-card-index {
    position: relative;
    background: #fafafa;
    border: 1px solid transparent;
    border-radius: 16px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-decoration: none;
    transition: transform 0.3s ease;
  }
  .svc-card-index:hover { transform: scale(1.01); }
  .svc-card-dark { border: 1.5px solid #FF4500; }

  .svc-img-box {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 12px;
    overflow: hidden;
    background: #eaeaea;
  }

  .svc-badge {
    position: absolute;
    top: 14px;
    right: 14px;
    background: #C53700;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    padding: 4px 10px;
    border-radius: 20px;
  }

  .svc-num  { font-size: 11px; font-weight: 600; color: #999; letter-spacing: 2px; margin: 0; }
  .svc-title { font-size: 18px; font-weight: 700; color: #111; margin: 4px 0; line-height: 1.2; }
  .svc-desc  { font-size: 13px; color: #666; line-height: 1.5; margin: 0; }

  .svc-card-dark .svc-num { color: #FF4500; }

  .svc-inline-link {
    color: #1a1a1a;
    font-weight: 600;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }
  .svc-inline-link:hover { color: #E63E00; }
</style>
