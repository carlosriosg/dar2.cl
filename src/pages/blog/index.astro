---
import Base from '../../layouts/Base.astro';
import Picture from '../../components/Picture.astro';

const breadcrumbs = [
  { name: 'Inicio', url: 'https://dar2.cl/' },
  { name: 'Blog', url: 'https://dar2.cl/blog/' },
];

// Lista de artículos. Cuando agregues nuevos, los pones aquí.
const articles = [
  {
    slug: 'streaming-corporativo-santiago-guia-completa',
    title: 'Streaming corporativo en Santiago: guía completa para empresas',
    excerpt: 'Guía completa de streaming corporativo en Santiago de Chile: qué es, tipos de eventos, equipamiento, plataformas, checklist para contratar productora y preguntas frecuentes.',
    date: '2026-05-26',
    readTime: '9 min',
    category: 'Streaming Corporativo',
    image: '/images/blog/streaming-junta-anual-hero.png',
  },
  {
    slug: 'que-es-live-shopping-chile',
    title: 'Qué es Live Shopping y cómo lo implementan las empresas en Chile',
    excerpt: 'Guía completa de live shopping: qué es, cómo funciona, plataformas, métricas y casos de uso en retail, farma y supermercados.',
    date: '2026-05-19',
    readTime: '8 min',
    category: 'Live Shopping',
    image: '/images/blog/live-shopping-hero.png',
  },
  {
    slug: 'transmitir-junta-anual-sin-caidas',
    title: 'Cómo transmitir tu junta anual de accionistas sin caídas técnicas',
    excerpt: 'Guía técnica: causas de caídas, multicámara, enlaces redundantes, plataformas (Zoom/Teams/YouTube) y checklist del día del evento.',
    date: '2026-05-12',
    readTime: '7 min',
    category: 'Streaming Corporativo',
    image: '/images/blog/streaming-junta-anual-hero.png',
  },
  {
    slug: 'estudio-virtual-vs-set-fisico',
    title: 'Estudio virtual vs. set físico: cuándo conviene cada uno',
    excerpt: 'Comparativa práctica de costos, tiempos, flexibilidad y calidad. Cuándo elegir green screen y cuándo construir un set real.',
    date: '2026-05-05',
    readTime: '6 min',
    category: 'Estudio Virtual',
    image: '/images/blog/estudio-virtual-vs-fisico-hero.png',
  },
  {
    slug: 'medir-roi-video-corporativo',
    title: 'Cómo medir el ROI de tu video corporativo: 5 métricas clave',
    excerpt: 'Views, retention, conversión, engagement y brand lift. Herramientas, benchmarks y un ejemplo de cálculo real de ROI.',
    date: '2026-04-28',
    readTime: '7 min',
    category: 'Video Corporativo',
    image: '/images/blog/roi-video-corporativo-hero.png',
  },
  {
    slug: 'filtros-ar-marca-instagram-tiktok',
    title: 'Filtros AR para marca: cómo funcionan y por qué tu empresa debería tener uno',
    excerpt: 'Guía completa de filtros de realidad aumentada para Instagram y TikTok: tipos, proceso de creación y métricas de alcance orgánico.',
    date: '2026-04-14',
    readTime: '6 min',
    category: 'Filtros AR',
    image: '/images/blog/filtros-ar-marca-hero.png',
  },
  {
    slug: 'circuito-cerrado-vs-streaming',
    title: 'Circuito cerrado vs. streaming: diferencias, cuándo usar cada uno y cómo combinarlos',
    excerpt: 'Comparativa técnica entre circuito cerrado CCTV y streaming en vivo. Cuándo conviene cada formato y cómo combinarlos en un mismo evento.',
    date: '2026-03-31',
    readTime: '5 min',
    category: 'Streaming Corporativo',
    image: '/images/blog/circuito-cerrado-vs-streaming-hero.png',
  },
  {
    slug: 'contenido-linkedin-ejecutivos',
    title: 'Cómo producir contenido para LinkedIn con tus ejecutivos como talento',
    excerpt: 'Guía práctica para grabar videos profesionales con ejecutivos sin experiencia frente a cámara: formato, duración, dirección y postproducción.',
    date: '2026-03-17',
    readTime: '6 min',
    category: 'Redes Sociales',
    image: '/images/blog/linkedin-ejecutivos-hero.png',
  },
  {
    slug: 'produccion-video-corporativo-paso-a-paso',
    title: 'Producción de video corporativo paso a paso: desde el brief hasta la entrega',
    excerpt: 'El proceso completo de producción de un video corporativo: preproducción, rodaje, postproducción y entregables. Con plazos referenciales.',
    date: '2026-03-03',
    readTime: '8 min',
    category: 'Video Corporativo',
    image: '/images/blog/produccion-video-corporativo-hero.png',
  },
];

// Schema Blog + ItemList para que Google muestre rich results de carousel
const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "@id": "https://dar2.cl/blog/#blog",
  "url": "https://dar2.cl/blog/",
  "name": "Blog DAR2 — Guías de producción audiovisual y digital",
  "description": "Artículos y guías sobre producción audiovisual, live shopping, streaming corporativo, video marketing y tendencias para empresas en Chile.",
  "inLanguage": "es-CL",
  "publisher": { "@id": "https://dar2.cl/#organization" },
  "blogPost": articles.map((a) => ({
    "@type": "BlogPosting",
    "headline": a.title,
    "url": `https://dar2.cl/blog/${a.slug}/`,
    "datePublished": a.date,
    "dateModified": a.date,
    "description": a.excerpt,
    "image": `https://dar2.cl${a.image}`,
    "author": { "@type": "Person", "name": "Carlos Rios Guevara", "url": "https://dar2.cl/nosotros/" },
    "publisher": { "@id": "https://dar2.cl/#organization" }
  }))
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Artículos del Blog DAR2",
  "itemListElement": articles.map((a, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `https://dar2.cl/blog/${a.slug}/`,
    "name": a.title
  }))
};
---

<Base
  title="Blog de Producción Audiovisual | DAR2"
  description="Artículos sobre producción audiovisual en Chile, live shopping, streaming corporativo, video marketing y tendencias para empresas."
  breadcrumbs={breadcrumbs}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  </Fragment>

  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-6 pt-16 md:pt-24 pb-12">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#666] mb-6">Blog</p>
    <h1 class="text-5xl md:text-6xl font-black tracking-tight leading-[1.05] mb-6 max-w-3xl">
      Guías de producción
      <em class="text-accent italic"> audiovisual y digital.</em>
    </h1>
    <p class="text-lg text-[#666] max-w-2xl leading-relaxed">
      Artículos sobre live shopping, streaming corporativo, video marketing y tendencias para empresas en Chile.
    </p>
  </section>

  <!-- Listado -->
  <section class="max-w-7xl mx-auto px-6 pb-24 border-t border-border pt-12">
    <ul class="blog-list">
      {articles.map(art => (
        <li class="blog-item">
          <a href={`/blog/${art.slug}/`} class="blog-link">
            <div class="blog-thumb">
              <Picture
                src={art.image}
                alt={art.title}
                width="730"
                height="411"
                class="blog-thumb-img"
                loading="lazy"
              />
            </div>
            <div class="blog-body">
              <p class="blog-meta">{art.category} · {art.readTime} de lectura</p>
              <h2 class="blog-title">{art.title}</h2>
              <p class="blog-excerpt">{art.excerpt}</p>
              <p class="blog-readmore">Leer artículo →</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>

</Base>

<style>
  .blog-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .blog-item {
    border-bottom: 1px solid #e5e5e5;
    padding-bottom: 40px;
  }
  .blog-item:last-child {
    border-bottom: none;
  }

  .blog-link {
    text-decoration: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    color: inherit;
  }
  @media (min-width: 768px) {
    .blog-link {
      grid-template-columns: 360px 1fr;
      gap: 32px;
      align-items: center;
    }
  }

  .blog-thumb {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: #eaeaea;
    transition: transform 0.3s ease;
  }
  .blog-thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .blog-link:hover .blog-thumb :global(img) {
    transform: scale(1.04);
  }

  .blog-body {
    display: flex;
    flex-direction: column;
  }

  .blog-meta {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #666;
    margin: 0 0 10px;
  }

  .blog-title {
    font-size: 24px;
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: -0.4px;
    margin: 0 0 10px;
    color: #1a1a1a;
    transition: color 0.2s ease;
  }
  @media (min-width: 768px) {
    .blog-title { font-size: 26px; }
  }

  .blog-link:hover .blog-title {
    color: #E63E00;
  }

  .blog-excerpt {
    font-size: 15px;
    line-height: 1.55;
    color: #555;
    margin: 0 0 12px;
  }

  .blog-readmore {
    font-size: 14px;
    font-weight: 700;
    color: #E63E00;
    margin: 0;
  }
</style>
