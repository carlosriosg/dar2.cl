---
import Base from '../layouts/Base.astro';
import VideoCard from '../components/VideoCard.astro';
import { getCollection } from 'astro:content';

const breadcrumbs = [
  { name: 'Inicio', url: 'https://dar2.cl/' },
  { name: 'Portafolio', url: 'https://dar2.cl/portafolio/' },
];

const todosLosItems = await getCollection('portafolio');
const ordenados = todosLosItems.sort((a, b) => b.data.anio - a.data.anio);

function getYouTubeId(url: string | undefined) {
  if (!url) return null;
  const m = url.match(/youtu\.be\/([a-zA-Z0-9_-]{6,15})/) ||
            url.match(/[?&]v=([a-zA-Z0-9_-]{6,15})/);
  return m ? m[1] : null;
}

// Generar VideoObject schema para cada proyecto con video
const videoSchemas = ordenados
  .filter(item => item.data.youtube_url)
  .map(item => {
    const videoId = getYouTubeId(item.data.youtube_url);
    const thumbnail = item.data.thumbnail
      ? `https://dar2.cl${item.data.thumbnail}`
      : `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;
    return {
      "@context": "https://schema.org",
      "@type": "VideoObject",
      "name": `${item.data.titulo} — ${item.data.cliente}`,
      "description": item.data.descripcion,
      "thumbnailUrl": thumbnail,
      "uploadDate": `${item.data.anio}-01-01`,
      "embedUrl": `https://www.youtube.com/embed/${videoId}`,
      "contentUrl": item.data.youtube_url,
      "publisher": { "@type": "Organization", "@id": "https://dar2.cl/#organization" }
    };
  });

const portafolioSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "url": "https://dar2.cl/portafolio/",
  "name": "Portafolio DAR2 — Proyectos audiovisuales",
  "description": "Proyectos de streaming corporativo, live shopping, videos institucionales y más. Clientes: Cencosud, ENAP, Clínica Santa María, ABCDIN, AFP Habitat y otros.",
  "publisher": { "@id": "https://dar2.cl/#organization" }
};
---

<Base
  title="Portafolio — Proyectos de streaming y video corporativo | DAR2"
  description="Conoce nuestros proyectos de streaming corporativo, live shopping, videos institucionales y producción audiovisual. Clientes como Cencosud, ENAP, Clínica Santa María y más."
  breadcrumbs={breadcrumbs}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(portafolioSchema)} />
    {videoSchemas.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>

  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-6 pt-16 md:pt-24 pb-16">
    <p class="text-xs font-semibold uppercase tracking-widest text-muted mb-6">Portafolio</p>
    <h1 class="text-5xl md:text-6xl font-black tracking-tight leading-[1.05] mb-6 max-w-3xl">
      Proyectos que hablan
      <em class="text-accent italic"> por sí solos.</em>
    </h1>
    <p class="text-lg text-muted max-w-2xl leading-relaxed">
      Streaming corporativo, live shopping, videos institucionales y producción audiovisual para empresas chilenas. Cada proyecto, un caso real.
    </p>
  </section>

  <!-- Intro: qué tipo de proyectos hacemos -->
  <section class="max-w-7xl mx-auto px-6 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="p-6 bg-[#fafafa] border border-border">
        <p class="text-xs font-bold uppercase tracking-widest text-accent mb-3">Streaming</p>
        <p class="text-sm text-muted leading-relaxed">
          Transmisiones en vivo multicámara con enlaces redundantes. Juntas anuales, lanzamientos y seminarios sin caídas.
          <a href="/servicios/streaming/" class="text-primary font-semibold hover:text-accent transition-colors">Ver servicio →</a>
        </p>
      </div>
      <div class="p-6 bg-[#fafafa] border border-border">
        <p class="text-xs font-bold uppercase tracking-widest text-accent mb-3">Live Shopping</p>
        <p class="text-sm text-muted leading-relaxed">
          Ventas en vivo con integración a e-commerce. Conducción profesional, gráficas en tiempo real y métricas de conversión.
          <a href="/servicios/live-shopping/" class="text-primary font-semibold hover:text-accent transition-colors">Ver servicio →</a>
        </p>
      </div>
      <div class="p-6 bg-[#fafafa] border border-border">
        <p class="text-xs font-bold uppercase tracking-widest text-accent mb-3">Videos Corporativos</p>
        <p class="text-sm text-muted leading-relaxed">
          Videos institucionales, de cultura y producto con cámara cinema y dirección creativa. 15 años produciendo para empresas del IPSA.
          <a href="/servicios/videos-corporativos/" class="text-primary font-semibold hover:text-accent transition-colors">Ver servicio →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- Grilla de proyectos -->
  <section class="max-w-7xl mx-auto px-6 pb-24 border-t border-border pt-12">
    <h2 class="text-2xl font-black tracking-tight mb-8">Proyectos recientes</h2>
    {ordenados.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
        {ordenados.map(item => (
          <VideoCard
            youtube_url={item.data.youtube_url}
            titulo={item.data.titulo}
            cliente={item.data.cliente}
            thumbnail={item.data.thumbnail}
          />
        ))}
      </div>
    ) : (
      <p class="text-muted text-lg">Pronto estaremos agregando nuestros proyectos aquí.</p>
    )}
  </section>

</Base>
