---
const { title, description, href, tag, num, featured = false } = Astro.props;
---

<div class={`border p-8 transition-colors group relative ${featured ? 'border-[#FF4500]' : 'border-[#e5e5e5] hover:border-[#1a1a1a]'}`}>

  {featured && (
    <span class="absolute top-4 right-4 text-[10px] font-bold uppercase tracking-widest text-[#FF4500] border border-[#FF4500] px-2 py-0.5">
      En tendencia
    </span>
  )}

  {num && (
    <span class="text-xs font-semibold text-[#666] mb-4 block">{num}</span>
  )}

  {tag && !num && (
    <span class="inline-block text-xs font-semibold uppercase tracking-widest text-[#666] mb-4">
      {tag}
    </span>
  )}

  <h3 class={`font-black text-xl tracking-tight mb-3 leading-tight ${featured ? 'text-[#FF4500]' : ''}`}>
    {title}
  </h3>

  <p class="text-[#666] text-sm leading-relaxed">
    {description}
  </p>

  {href && (
    <a
      href={href}
      class="inline-flex items-center gap-1.5 text-sm font-semibold mt-6 text-[#1a1a1a] hover:text-[#FF4500] transition-colors"
    >
      Ver más <span class="group-hover:translate-x-0.5 transition-transform inline-block">→</span>
    </a>
  )}
</div>
