---
import Picture from './Picture.astro';
---

<footer class="site-footer">
  <div class="footer-container">

    <!-- Col 1: Logo + descripción breve + dirección -->
    <div class="footer-col footer-brand">
      <div class="footer-logo-wrap">
        <Picture
          src="/images/galeria/dar2_logo_firma.png"
          alt="DAR2 — Productora audiovisual"
          width="136"
          height="40"
          loading="lazy"
          decoding="async"
          class="footer-logo-img"
        />
      </div>
      <p class="footer-tagline">
        Productora audiovisual en Santiago.
        15 años creando contenido para marcas.
      </p>
      <p class="footer-address">
        Av. Holanda 099, Oficina 603<br />
        Providencia, Santiago
      </p>
    </div>

    <!-- Col 2: Servicios -->
    <div class="footer-col">
      <p class="footer-heading">Servicios</p>
      <ul class="footer-list footer-list--services">
        <li><a href="/servicios/streaming/">Streaming</a></li>
        <li><a href="/servicios/live-shopping/">Live Shopping</a></li>
        <li><a href="/servicios/circuito-cerrado/">Multicámara para Eventos</a></li>
        <li><a href="/servicios/estudio-virtual/">Estudio Virtual</a></li>
        <li><a href="/servicios/videos-corporativos/">Videos Corporativos</a></li>
        <li><a href="/servicios/estrategias-digitales/">Estrategias Digitales</a></li>
        <li><a href="/servicios/redes-sociales/">Redes Sociales</a></li>
        <li><a href="/servicios/filtros-ar/">Filtros AR</a></li>
      </ul>
    </div>

    <!-- Col 3: Empresa -->
    <div class="footer-col">
      <p class="footer-heading">Empresa</p>
      <ul class="footer-list">
        <li><a href="/portafolio/">Portafolio</a></li>
        <li><a href="/casos/">Casos de éxito</a></li>
        <li><a href="/blog/">Blog</a></li>
        <li><a href="/nosotros/">Nosotros</a></li>
        <li><a href="/contacto/">Contacto</a></li>
      </ul>
    </div>

    <!-- Col 4: Contacto + redes -->
    <div class="footer-col">
      <p class="footer-heading">Contacto</p>
      <ul class="footer-list">
        <li>
