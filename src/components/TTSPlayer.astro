---
// Reproductor TTS (Text-to-Speech) usando Web Speech API.
// Lee en voz alta el contenido del <article> más cercano.
// Sin dependencias externas — funciona en Chrome, Edge, Safari, Firefox.
---

<div class="tts-wrap" id="tts-root">
  <button class="tts-btn" id="tts-btn" aria-label="Escuchar artículo" title="Escuchar artículo">
    <span class="tts-icon" id="tts-icon">▶</span>
    <span class="tts-label" id="tts-label">Escuchar artículo</span>
    <span class="tts-time" id="tts-time"></span>
  </button>
  <div class="tts-progress" id="tts-progress">
    <div class="tts-progress-bar" id="tts-progress-bar"></div>
  </div>
</div>

<script>
  // @ts-nocheck
  (() => {
    const btn = document.getElementById('tts-btn');
    const icon = document.getElementById('tts-icon');
    const label = document.getElementById('tts-label');
    const timeEl = document.getElementById('tts-time');
    const progressBar = document.getElementById('tts-progress-bar');

    if (!('speechSynthesis' in window)) {
      label.textContent = 'TTS no disponible';
      btn.disabled = true;
      return;
    }

    // --- Estado ---
    const STATE = { IDLE: 0, PLAYING: 1, PAUSED: 2 };
    let state = STATE.IDLE;
    let utterance = null;
    let chunks = [];
    let currentChunk = 0;
    let totalChars = 0;
    let spokenChars = 0;
    let resumeOffset = 0;

    // --- Obtener texto del artículo ---
    function getArticleText() {
      const article = document.querySelector('article');
      if (!article) return '';
      // Clonar para no modificar el DOM
      const clone = article.cloneNode(true);
      // Remover elementos no deseados
      clone.querySelectorAll('.article-toc, .article-cta, .article-cta-final, .article-faq, .article-hero-image, .article-meta, script, style, nav, .tts-wrap').forEach(el => el.remove());
      // Extraer texto de párrafos y headings
      const parts = [];
      clone.querySelectorAll('p, h2, h3, h4, li, .article-lead').forEach(el => {
        const text = el.textContent.trim();
        if (text) parts.push(text);
      });
      return parts.join('. ');
    }

    // --- Dividir en chunks (límite ~200 caracteres para mejor control) ---
    function splitIntoChunks(text) {
      const sentences = text.match(/[^.!?]+[.!?]+/g) || [text];
      const result = [];
      let current = '';
      for (const s of sentences) {
        if ((current + s).length > 200 && current.length > 0) {
          result.push(current.trim());
          current = s;
        } else {
          current += ' ' + s;
        }
      }
      if (current.trim()) result.push(current.trim());
      return result;
    }

    // --- Formatear tiempo ---
    function formatTime(ms) {
      const totalSec = Math.floor(ms / 1000);
      const min = Math.floor(totalSec / 60);
      const sec = totalSec % 60;
      return `${min}:${sec.toString().padStart(2, '0')}`;
    }

    // --- Estimar duración (~150 ms por carácter) ---
    function estimateDuration(text) {
      return text.length * 150;
    }

    // --- Leer chunk ---
    function speakChunk(index) {
      if (index >= chunks.length) {
        resetUI();
        return;
      }

      currentChunk = index;
      const text = chunks[index];
      utterance = new SpeechSynthesisUtterance(text);
      utterance.lang = 'es-CL';
      utterance.rate = 1.0;
      utterance.pitch = 1.0;

      // Intentar usar voz en español
      const voices = speechSynthesis.getVoices();
      const esVoice = voices.find(v => v.lang.startsWith('es'));
      if (esVoice) utterance.voice = esVoice;

      utterance.onstart = () => {
        state = STATE.PLAYING;
        icon.textContent = '⏸';
        label.textContent = 'Reproduciendo…';
      };

      utterance.onend = () => {
        spokenChars += text.length;
        updateProgress();
        speakChunk(index + 1);
      };

      utterance.onerror = () => {
        speakChunk(index + 1);
      };

      speechSynthesis.speak(utterance);
    }

    // --- Actualizar barra de progreso ---
    function updateProgress() {
      const pct = totalChars > 0 ? Math.min((spokenChars / totalChars) * 100, 100) : 0;
      progressBar.style.width = pct + '%';
      const elapsed = estimateDuration(spokenChars);
      const total = estimateDuration(totalChars);
      timeEl.textContent = `${formatTime(elapsed)} / ${formatTime(total)}`;
    }

    // --- Reset UI ---
    function resetUI() {
      state = STATE.IDLE;
      icon.textContent = '▶';
      label.textContent = 'Escuchar artículo';
      timeEl.textContent = '';
      progressBar.style.width = '0%';
      chunks = [];
      currentChunk = 0;
      totalChars = 0;
      spokenChars = 0;
      resumeOffset = 0;
      utterance = null;
    }

    // --- Iniciar reproducción ---
    function start() {
      speechSynthesis.cancel();
      const text = getArticleText();
      if (!text) {
        label.textContent = 'Sin contenido';
        return;
      }
      chunks = splitIntoChunks(text);
      totalChars = text.length;
      spokenChars = 0;
      currentChunk = 0;
      resumeOffset = 0;
      updateProgress();
      speakChunk(0);
    }

    // --- Pausar ---
    function pause() {
      if (state === STATE.PLAYING) {
        speechSynthesis.pause();
        state = STATE.PAUSED;
        icon.textContent = '▶';
        label.textContent = 'Pausado';
      }
    }

    // --- Reanudar ---
    function resume() {
      if (state === STATE.PAUSED) {
        speechSynthesis.resume();
        state = STATE.PLAYING;
        icon.textContent = '⏸';
        label.textContent = 'Reproduciendo…';
      }
    }

    // --- Detener ---
    function stop() {
      speechSynthesis.cancel();
      resetUI();
    }

    // --- Click handler ---
    btn.addEventListener('click', () => {
      if (state === STATE.IDLE) {
        start();
      } else if (state === STATE.PLAYING) {
        pause();
      } else if (state === STATE.PAUSED) {
        resume();
      }
    });

    // --- Detener al salir de la página ---
    document.addEventListener('visibilitychange', () => {
      if (document.hidden && state === STATE.PLAYING) {
        pause();
      }
    });

    // --- Precargar voces (pueden tardar en cargar) ---
    if (speechSynthesis.getVoices().length === 0) {
      speechSynthesis.addEventListener('voiceschanged', () => {
        speechSynthesis.getVoices();
      }, { once: true });
    }
  })();
</script>

<style>
  .tts-wrap {
    margin-bottom: 32px;
    user-select: none;
  }
  .tts-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #f5f5f5;
    border: 1px solid #e5e5e5;
    border-radius: 100px;
    padding: 10px 20px;
    cursor: pointer;
    font-family: inherit;
    font-size: 14px;
    color: #1a1a1a;
    transition: background 0.2s ease, border-color 0.2s ease;
    width: 100%;
    max-width: 340px;
  }
  .tts-btn:hover {
    background: #eee;
    border-color: #ccc;
  }
  .tts-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .tts-icon {
    font-size: 14px;
    width: 20px;
    text-align: center;
  }
  .tts-label {
    flex: 1;
    text-align: left;
    font-weight: 600;
  }
  .tts-time {
    font-size: 12px;
    color: #888;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .tts-progress {
    margin-top: 8px;
    height: 3px;
    background: #e5e5e5;
    border-radius: 2px;
    overflow: hidden;
    max-width: 340px;
  }
  .tts-progress-bar {
    height: 100%;
    width: 0%;
    background: #FF4500;
    border-radius: 2px;
    transition: width 0.3s ease;
  }
</style>
