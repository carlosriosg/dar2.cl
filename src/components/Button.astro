---
const { variant = 'primary', href, type = 'button', class: className = '' } = Astro.props;

const base = 'inline-flex items-center justify-center gap-2 text-sm font-semibold px-6 py-3 transition-colors cursor-pointer';

const variants = {
  primary: 'bg-[#1a1a1a] text-white hover:bg-[#333]',
  secondary: 'bg-white text-[#1a1a1a] border border-[#1a1a1a] hover:bg-[#f5f5f5]',
  accent: 'bg-[#FF4500] text-white hover:bg-[#e03d00]',
  ghost: 'text-[#666] hover:text-[#1a1a1a] px-0',
};
---

{href ? (
  <a href={href} class={`${base} ${variants[variant]} ${className}`}>
    <slot />
  </a>
) : (
  <button type={type} class={`${base} ${variants[variant]} ${className}`}>
    <slot />
  </button>
)}
