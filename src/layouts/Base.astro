---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import '@fontsource-variable/inter/index.css';
import '@fontsource-variable/inter/wght-italic.css';
import '../styles/global.css';

// Imports de las 2 fuentes Inter latinas más usadas (normal + italic) para
// preload. Astro/Vite resuelve el path con hash automáticamente. Reduce la
// cadena crítica de ~629ms del audit de PageSpeed.
import interLatinNormal from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import interLatinItalic from '@fontsource-variable/inter/files/inter-latin-wght-italic.woff2?url';

const {
  title = 'Productora Audiovisual en Santiago | DAR2',
  description = 'Productora audiovisual en Chile especializada en streaming, live shopping, videos corporativos, estudio virtual y filtros AR. Más de 15 años trabajando con Cencosud, ENAP, Clínica Santa María, ABCDIN y más.',
  breadcrumbs = null,
  preloadImage = null,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://dar2.cl');
const fullTitle = title.includes('| DAR2') ? title : `${title} | DAR2`;
const isHome = Astro.url.pathname === '/';

// Schema unificado: LocalBusiness + ProfessionalService bajo un mismo @id.
// NOTA: postal code y coordenadas a verificar con Correos de Chile y Google Maps.
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "ProfessionalService"],
  "@id": "https://dar2.cl/#organization",
  "name": "DAR2 Servicios Audiovisuales",
  "alternateName": "DAR2",
  "description": "Productora audiovisual chilena con más de 15 años de experiencia, especializada en streaming corporativo, live shopping, videos corporativos, estudio virtual, circuito cerrado, estrategias digitales, redes sociales y filtros AR.",
  "url": "https://dar2.cl/",
  "logo": {
    "@type": "ImageObject",
    "url": "https://dar2.cl/images/galeria/dar2_logo_firma.png",
    "width": 600,
    "height": 200
  },
  "image": "https://dar2.cl/og-square.png",
  "telephone": "+56998433346",
  "email": "dar2@dar2.cl",
  "foundingDate": "2010-01-01",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Av. Holanda 099, Oficina 603",
    "addressLocality": "Providencia",
    "addressRegion": "Región Metropolitana",
    "postalCode": "7510689",
    "addressCountry": "CL"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -33.418232666829546,
    "longitude": -70.60460118861644
  },
  "areaServed": { "@type": "Country", "name": "Chile" },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "09:00",
    "closes": "19:00"
  }],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": 5.0,
    "reviewCount": 12,
    "bestRating": 5,
    "worstRating": 1
  },
  "founder": {
    "@type": "Person",
    "name": "Carlos Rios Guevara",
    "jobTitle": "Director",
    "alumniOf": { "@type": "CollegeOrUniversity", "name": "UNIACC" }
  },
  "sameAs": [
    "https://www.instagram.com/dar2.cl",
    "https://www.linkedin.com/company/dar2",
    "https://www.google.com/maps?cid=6666778595618035561"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios audiovisuales",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Streaming corporativo", "url": "https://dar2.cl/servicios/streaming/" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Live Shopping", "url": "https://dar2.cl/servicios/live-shopping/" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Circuito Cerrado CCTV", "url": "https://dar2.cl/servicios/circuito-cerrado/" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Estudio Virtual", "url": "https://dar2.cl/servicios/estudio-virtual/" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Videos Corporativos", "url": "https://dar2.cl/servicios/videos-corporativos/" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Estrategias Digitales", "url": "https://dar2.cl/servicios/estrategias-digitales/" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Redes Sociales", "url": "https://dar2.cl/servicios/redes-sociales/" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Filtros AR", "url": "https://dar2.cl/servicios/filtros-ar/" }}
    ]
  }
};

// WebSite schema (sin SearchAction — el endpoint /search?q= no existe).
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://dar2.cl/#website",
  "url": "https://dar2.cl/",
  "name": "DAR2 Servicios Audiovisuales",
  "description": "Productora audiovisual en Santiago de Chile especializada en streaming, live shopping y video corporativo.",
  "publisher": { "@id": "https://dar2.cl/#organization" },
  "inLanguage": "es-CL"
};

// BreadcrumbList opcional: el page padre puede pasar un array de items.
const breadcrumbSchema = breadcrumbs ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((b: { name: string; url: string }, i: number) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": b.name,
    "item": b.url
  }))
} : null;
---

<!DOCTYPE html>
<html lang="es-CL">
  <head>
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-5NBSGWM5');</script>
    <!-- End Google Tag Manager -->

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="es-CL" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    )}
    <meta name="author" content="DAR2 Servicios Audiovisuales" />
    <meta name="geo.region" content="CL-RM" />
    <meta name="geo.placename" content="Santiago, Chile" />
    <meta name="language" content="Spanish" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:site_name" content="DAR2" />

    <!-- OG Image principal: cuadrada 1200x1200 (WhatsApp toma la primera que encuentra) -->
    <meta property="og:image" content="https://dar2.cl/og-square.png" />
    <meta property="og:image:secure_url" content="https://dar2.cl/og-square.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="1200" />
    <meta property="og:image:alt" content="DAR2 — Productora audiovisual en Santiago de Chile" />

    <!-- OG Image secundaria: rectangular 1200x630 (Facebook / LinkedIn eligen la mejor según contexto) -->
    <meta property="og:image" content="https://dar2.cl/og-rect.png" />
    <meta property="og:image:secure_url" content="https://dar2.cl/og-rect.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="DAR2 — Streaming, live shopping y más" />

    <!-- Twitter / X (usa card grande con imagen rectangular) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://dar2.cl/og-rect.png" />
    <meta name="twitter:image:alt" content="DAR2 — Productora audiovisual en Santiago de Chile" />

    <!-- Schema.org: Organization (LocalBusiness + ProfessionalService unificados) -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    <!-- Schema.org: WebSite con SearchAction (habilita Sitelinks Search Box) -->
    {isHome && <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />}

    <!-- Schema.org: Person (Carlos Rios Guevara — E-E-A-T) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": "https://dar2.cl/#person",
      "name": "Carlos Rios Guevara",
      "jobTitle": "Director",
      "worksFor": { "@id": "https://dar2.cl/#organization" },
      "alumniOf": { "@type": "CollegeOrUniversity", "name": "UNIACC" },
      "sameAs": [
        "https://www.linkedin.com/in/carlos-rios-guevara-9a1b5a2b/",
        "https://www.instagram.com/dar2.cl"
      ],
      "url": "https://dar2.cl/nosotros/"
    }
    </script>

    <!-- Schema.org: BreadcrumbList (cuando el page lo pasa) -->
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}

    <!-- Preload LCP image (cuando el page lo indica) -->
    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} type="image/webp" fetchpriority="high" />
    )}

    <!-- Preconnect hints para orígenes críticos de terceros -->
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="preconnect" href="https://w.behold.so" crossorigin />
    <link rel="preconnect" href="https://api.web3forms.com" crossorigin />

    <!-- Preload Inter latin fonts (normal + italic) para reducir cadena critica.
         crossorigin requerido aun para mismo origen porque <link rel=preload as=font>
         siempre lo necesita por especificacion (CORS mode). -->
    <link rel="preload" as="font" type="font/woff2" href={interLatinNormal} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={interLatinItalic} crossorigin />

    <!-- Favicons (cuadrado naranja DAR2 + camara blanca, visible en light y dark) -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=3" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=3" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=3" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png?v=3" />

    <!-- Apple touch icon (iOS) -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=3" />

    <!-- Para Android / PWA-lite -->
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png?v=3" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png?v=3" />
    <meta name="theme-color" content="#FF4500" />
    <meta name="msapplication-TileColor" content="#FF4500" />

    <!-- Inter font self-hosted via @fontsource-variable/inter (importado arriba en el frontmatter) -->

    <slot name="head" />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5NBSGWM5"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- ── Global Video Lightbox ────────────────────────── -->
    <div
      id="dar2-lightbox"
      class="fixed inset-0 z-50 hidden bg-black/85 items-center justify-center p-4 md:p-10"
      role="dialog"
      aria-modal="true"
      aria-label="Reproductor de video"
    >
      <div class="relative w-full max-w-4xl">
        <button
          id="dar2-lightbox-close"
          aria-label="Cerrar video"
          class="absolute -top-10 right-0 flex items-center gap-2 text-white/70 hover:text-white text-sm font-semibold transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
          Cerrar
        </button>
        <div class="aspect-video bg-black">
          <iframe
            id="dar2-lightbox-iframe"
            class="w-full h-full"
            frameborder="0"
            allowfullscreen
            allow="autoplay; encrypted-media; picture-in-picture"
          ></iframe>
        </div>
      </div>
    </div>

    <script>
      const lb      = document.getElementById('dar2-lightbox') as HTMLElement | null;
      const iframe  = document.getElementById('dar2-lightbox-iframe') as HTMLIFrameElement | null;
      const closeBtn = document.getElementById('dar2-lightbox-close') as HTMLElement | null;

      function openLb(embed: string) {
        if (!lb || !iframe) return;
        iframe.src = embed + '?autoplay=1&rel=0&modestbranding=1';
        lb.classList.remove('hidden');
        lb.classList.add('flex');
        document.body.style.overflow = 'hidden';
      }

      function closeLb() {
        if (!lb || !iframe) return;
        lb.classList.add('hidden');
        lb.classList.remove('flex');
        iframe.src = '';
        document.body.style.overflow = '';
      }

      window.addEventListener('dar2:open-video', ((e: CustomEvent) => openLb(e.detail.embed)) as EventListener);
      closeBtn?.addEventListener('click', closeLb);
      lb?.addEventListener('click', (e: MouseEvent) => { if (e.target === lb) closeLb(); });
      document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape' && !lb?.classList.contains('hidden')) closeLb();
      });
    </script>
    <ScrollToTop />

    <!-- ── WhatsApp Floating Button ──────────────────────── -->
    <a
      href="https://wa.me/56998433346?text=Hola%20DAR2%2C%20me%20interesa%20cotizar%20un%20proyecto%20audiovisual.%20%C2%BFPodemos%20hablar%3F"
      target="_blank"
      rel="noopener"
      class="whatsapp-float"
      aria-label="Escríbenos por WhatsApp"
      title="Escríbenos por WhatsApp"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span class="whatsapp-float-label">WhatsApp</span>
    </a>

    <style>
      /* ── WhatsApp Floating Button ────────────────────── */
      .whatsapp-float {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9998;
        display: flex;
        align-items: center;
        gap: 8px;
        background: #25D366;
        color: #fff;
        padding: 12px 18px;
        border-radius: 50px;
        text-decoration: none;
        box-shadow: 0 4px 16px rgba(37, 211, 102, 0.35);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        font-size: 14px;
        font-weight: 700;
        line-height: 1;
      }

      .whatsapp-float:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 24px rgba(37, 211, 102, 0.5);
        color: #fff;
      }

      .whatsapp-float-label {
        display: none;
      }

      @media (min-width: 640px) {
        .whatsapp-float {
          padding: 14px 22px;
          gap: 10px;
        }
        .whatsapp-float-label {
          display: inline;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .whatsapp-float {
          transition: none;
        }
      }
    </style>
  </body>
</html>
